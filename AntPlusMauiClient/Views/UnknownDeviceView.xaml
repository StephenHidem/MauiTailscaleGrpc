<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AntPlusMauiClient.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             x:DataType="vm:UnknownDeviceViewModel"
             x:Class="AntPlusMauiClient.Views.UnknownDeviceView">
    <VerticalStackLayout>
        <CollectionView ItemsSource="{Binding DataPages}">
            <CollectionView.Header>
                <Label Text="Data Pages" Style="{StaticResource HeaderLabelStyle}"/>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="sys:Array">
                    <Label Text="{Binding ., Converter={StaticResource ByteArrayToString}}" FontFamily="CascadiaCode" Margin="10, 0" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentView>
