<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AntPlusMauiClient.ViewModels"
             xmlns:views="clr-namespace:AntPlusMauiClient.Views"
             xmlns:tabview="clr-namespace:Syncfusion.Maui.Toolkit.TabView;assembly=Syncfusion.Maui.Toolkit"
             xmlns:picker="clr-namespace:Syncfusion.Maui.Toolkit.Picker;assembly=Syncfusion.Maui.Toolkit"
             x:DataType="vm:MuscleOxygenViewModel"
             x:Class="AntPlusMauiClient.Views.MuscleOxygenView">

    <tabview:SfTabView>
        <tabview:SfTabView.Items>
            <tabview:SfTabItem Header="Muscle Oxygen">
                <tabview:SfTabItem.Content>
                    <ScrollView>
                        <VerticalStackLayout>
                            <Border>
                                <VerticalStackLayout>
                                    <Label Text="Main Data Page" Style="{StaticResource HeaderLabelStyle}"/>
                                    <Label Text="{Binding MuscleOxygen.SupportsAntFs, StringFormat='Supports ANT-FS: {0}'}"/>
                                    <Label Text="{Binding MuscleOxygen.UtcTimeRequired, StringFormat='UTC time required: {0}'}"/>
                                    <Label Text="{Binding MuscleOxygen.Interval, StringFormat='Measurement Interval: {0}'}"/>
                                    <Label Text="{Binding MuscleOxygen.TotalHemoglobinConcentration.Concentration, StringFormat='Total Hq concentration: {0}'}"/>
                                    <Label Text="{Binding MuscleOxygen.TotalHemoglobinConcentration.Status, StringFormat='Total Hq status: {0}'}"/>
                                    <Label Text="{Binding MuscleOxygen.PreviousSaturatedHemoglobin.PercentSaturated, StringFormat='Previous saturated Hg: {0}'}"/>
                                    <Label Text="{Binding MuscleOxygen.PreviousSaturatedHemoglobin.Status, StringFormat='Previous saturated Hq status: {0}'}"/>
                                    <Label Text="{Binding MuscleOxygen.CurrentSaturatedHemoglobin.PercentSaturated, StringFormat='Current saturated Hg: {0}'}"/>
                                    <Label Text="{Binding MuscleOxygen.CurrentSaturatedHemoglobin.Status, StringFormat='Current saturated Hq status: {0}'}"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border>
                                <VerticalStackLayout>
                                    <Label Text="Local Time Offset" Style="{StaticResource HeaderLabelStyle}"/>
                                    <HorizontalStackLayout>
                                        <picker:SfPicker x:Name="Picker" Mode="Dialog" IsOpen="{Binding IsPickerOpen, Mode=TwoWay}">
                                            <picker:SfPicker.HeaderView>
                                                <picker:PickerHeaderView Text="Local Time Offset" Height="40"
                                                                 Background="{AppThemeBinding Dark={StaticResource PrimaryDark}, Light={StaticResource Primary}}"/>
                                            </picker:SfPicker.HeaderView>
                                            <picker:SfPicker.Columns>
                                                <picker:PickerColumn HeaderText="Hours"
                                                             ItemsSource="{Binding Source={x:Static vm:MuscleOxygenViewModel.HoursSource}}"
                                                             SelectedIndex="{Binding HoursIndex, Mode=TwoWay}"/>
                                                <picker:PickerColumn HeaderText="Minutes"
                                                             ItemsSource="{Binding Source={x:Static vm:MuscleOxygenViewModel.MinutesSource}}"
                                                             SelectedIndex="{Binding MinutesIndex, Mode=TwoWay}"/>
                                            </picker:SfPicker.Columns>
                                            <picker:SfPicker.ColumnHeaderView>
                                                <picker:PickerColumnHeaderView Height="40"/>
                                            </picker:SfPicker.ColumnHeaderView>
                                        </picker:SfPicker>
                                        <Button Margin="4" Text="{Binding LocalTimeOffset}"
                                                WidthRequest="84"
                                                Command="{Binding GetLocalTimeOffsetCommand}"/>
                                        <Button Margin="4" Text="Set Time"
                                                Command="{Binding SetTimeCommand}"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                            <Border>
                                <Grid ColumnSpacing="16" RowSpacing="8" RowDefinitions="Auto, Auto" ColumnDefinitions="Auto, Auto, Auto">
                                    <Label Text="Session Control" Style="{StaticResource HeaderLabelStyle}" Grid.ColumnSpan="3"/>
                                    <Button Grid.Column="0" Grid.Row="1" Text="Start" Command="{Binding StartSessionCommand}"/>
                                    <Button Grid.Column="1" Grid.Row="1" Text="Stop" Command="{Binding StopSessionCommand}"/>
                                    <Button Grid.Column="2" Grid.Row="1" Text="Lap" Command="{Binding LogLapCommand}"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </ScrollView>
                </tabview:SfTabItem.Content>
            </tabview:SfTabItem>
            <tabview:SfTabItem Header="Common Data Pages">
                <tabview:SfTabItem.Content>
                    <views:CommonDataPagesView CommonDataPages="{Binding MuscleOxygen.CommonDataPages}"/>
                </tabview:SfTabItem.Content>
            </tabview:SfTabItem>
        </tabview:SfTabView.Items>
    </tabview:SfTabView>
</ContentView>
